# =============================================================================
# Hub 3S — Variáveis de Ambiente (modelo)
# =============================================================================
# Copie este arquivo para `.env` e preencha os valores reais.
# O `.env` é ignorado pelo Git (ver .gitignore) e NUNCA deve ser commitado.
#
# AMBIENTE PADRÃO PARA DESENVOLVIMENTO LOCAL: Supabase DEV (xcqfdnymadeqeuacqotu).
#   - Use o DEV para experimentar sem afetar dados reais de produção.
#   - Pegue as chaves em:
#     https://supabase.com/dashboard/project/xcqfdnymadeqeuacqotu/settings/api
#
# ATENÇÃO (segurança / produção):
#   - Use apenas a chave PUBLISHABLE (anon) no frontend — NUNCA a service_role.
#   - A SUPABASE_SERVICE_ROLE_KEY é SECRETA: preencha só se precisar de SSR/admin
#     local, mantenha apenas no seu .env e nunca a exponha/commit.
#   - Se estas variáveis ficarem em branco, o app usa valores padrão embutidos no
#     código que apontam para o ambiente PRINCIPAL (produção). Para trabalhar no
#     DEV, preencha as variáveis abaixo.
# =============================================================================

# --- Cliente (Vite, build-time / browser) ------------------------------------
VITE_SUPABASE_URL="https://xcqfdnymadeqeuacqotu.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."   # DEV publishable (anon) key
VITE_SUPABASE_PROJECT_ID="xcqfdnymadeqeuacqotu"

# --- Servidor (SSR / TanStack Start) -----------------------------------------
SUPABASE_URL="https://xcqfdnymadeqeuacqotu.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."        # mesma publishable (anon) key

# --- Servidor (admin / bypass RLS) — SECRETO, opcional -----------------------
# Só necessário para funções/rotas de servidor que usam o cliente admin.
# Deixe comentado se não precisar; NUNCA commite o valor real.
# SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
