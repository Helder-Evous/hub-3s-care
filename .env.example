# Supabase — copie este arquivo para .env e preencha com os valores do seu projeto.
# Nunca commite o arquivo .env com valores reais.
# Obtenha as chaves em: https://supabase.com/dashboard/project/<project-id>/settings/api
#
# Use apenas a chave PUBLISHABLE (anon) no frontend.
# A SERVICE_ROLE key NUNCA deve ser definida aqui — ela só vai em variáveis
# de ambiente do servidor (ex.: Cloudflare Workers secrets, CI/CD secrets).

SUPABASE_URL="https://<project-id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

VITE_SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_PROJECT_ID="<project-id>"
